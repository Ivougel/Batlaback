{
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "dev": "vite",
    "dev:bundle": "npm run generate:vite-entry && vite --open /index.vite.html",
    "generate:vite-entry": "node tools/generate-vite-entry.mjs",
    "build": "npm run compile:ts && npm run generate:vite-entry && vite build && node tools/post-vite-build.mjs",
    "preview": "vite preview",
    "compile:ts": "node tools/compile-ts.mjs",
    "typecheck": "npm run compile:ts && tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.compile.json",
    "test:unit": "vitest run",
    "test:game": "npm run test:unit",
    "test:mutations": "node tools/mutation-capstones.test.mjs",
    "test:mutation-ui": "node tools/mutation-ui.test.mjs && npx playwright test tools/mutation-gallery.spec.mjs",
    "test:item-pool": "node tools/item-pool-120.test.mjs",
    "generate:item-pool": "node tools/generate-item-pool-120.mjs",
    "generate:bb-unlocks": "node tools/generate-bb-unlock-tiers.mjs",
    "generate:bb-recipes": "node tools/generate-bb-recipes.mjs",
    "sync:craft-flags": "node tools/generate-bb-recipes.mjs && node tools/sync-item-craft-flags.mjs --write && node tools/generate-items-catalog.js",
    "import:bb-items": "node tools/import-bb-reference-items.mjs",
    "generate:placement-slots": "node tools/generate-placement-slots.mjs && npm run compile:ts",
    "test:placement-slots": "node tools/placement-slots.test.mjs && node tools/placement-slots-audit.mjs",
    "patch:pool120-descriptions": "node tools/patch-pool120-item-descriptions.mjs",
    "audit:mechanics": "node tools/item-mechanics-audit.mjs",
    "audit:max-account": "node tools/audit-max-account-pool.mjs",
    "export:pool120": "node tools/export-pool120-items.mjs",
    "generate:pool120-presets": "node tools/generate-class-pool120-presets.js",
    "sim:balance-pool120": "node tools/generate-class-pool120-presets.js && node tools/class-balance-pool120-sim.js --json",
    "test:runtime-loader": "node tools/runtime-loader.test.mjs",
    "test:meta": "node tools/meta-progress.test.mjs && node tools/bb-classic.test.mjs && node tools/max-account-pool.test.mjs && node tools/item-craft-audit.test.mjs && node tools/bb-fidelity.test.mjs && node tools/bb-prep-board.test.mjs && node tools/prep-drag-hover.test.mjs && node tools/bb-craft.test.mjs && node tools/bb-craft-cluster.test.mjs && node tools/prep-storage-fling.test.mjs && node tools/battle-legacy-fx.test.mjs",
    "test:placement-slots": "node tools/placement-slots.test.mjs",
    "audit:placement-slots": "node tools/placement-slots-audit.mjs",
    "test:layout": "node tools/layout-profiles.test.mjs",
    "test:structure": "node tools/ui-structure.test.mjs",
    "test:phases": "node tools/layout-phases.test.mjs",
    "test:geometry": "node tools/layout-geometry.test.mjs",
    "test:y700-intro": "node tools/y700-intro-controls.test.mjs",
    "test:desktop-prep": "node tools/desktop-prep-layout.test.mjs",
    "test:qa": "node tools/layout-qa-audit.mjs",
    "test:drag-stability": "node tools/layout-drag-stability.test.mjs",
    "test:prep-drag-alignment": "node tools/prep-drag-alignment.test.mjs",
    "test:phase-smoothness": "node tools/layout-phase-smoothness.test.mjs",
    "test:transitions": "npm run test:phases && npm run test:phase-smoothness && npm run test:drag-stability",
    "test:snapshots": "playwright test",
    "test:snapshots:prep": "playwright test tools/prep-snapshots.spec.mjs tools/layout-snapshots.spec.mjs",
    "test:snapshots:update": "playwright test --update-snapshots",
    "test:ui": "npm run test:layout && npm run test:structure && npm run test:transitions && npm run test:geometry && npm run test:qa && npm run test:snapshots",
    "profile:battle": "node tools/battle-perf-profile.mjs",
    "profile:transitions": "node tools/transition-perf-profile.mjs",
    "test:perf": "node tools/battle-perf-profile.mjs --assert && node tools/transition-perf-profile.mjs --assert",
    "generate:pwa-precache": "node tools/generate-pwa-precache.js",
    "audit:transitions": "node tools/audit-phase-transitions.mjs"
  },
  "dependencies": {
    "@playwright/test": "^1.49.0",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "esbuild": "^0.28.1",
    "serve": "^14.2.6",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.10"
  }
}
