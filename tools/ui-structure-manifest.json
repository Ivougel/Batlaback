{
  "version": 2,
  "fixedAt": "2026-07-04",
  "gameModes": ["solo", "versus", "hardbot", "lobby", "lobby2p", "campaign"],
  "phases": {
    "js": ["classSelect", "prep", "battle", "replay"],
    "appDataset": ["prep", "battle", "replay"]
  },
  "classIntroSteps": [
    { "key": "mode", "elementId": "class-step-mode", "overlayAttr": "mode" },
    { "key": "campaignTrial", "elementId": "class-step-campaign", "overlayAttr": "campaignTrial" },
    { "key": "player", "elementId": "class-step-player", "overlayAttr": "player" },
    { "key": "companion", "elementId": "class-step-companion", "overlayAttr": "companion" },
    { "key": "summary", "elementId": "class-step-summary", "overlayAttr": "summary" },
    { "key": "opponent", "elementId": "class-step-opponent", "overlayAttr": "opponent" }
  ],
  "overlays": [
    { "id": "class-overlay", "layer": "menu", "hiddenByDefault": false },
    { "id": "escape-menu-overlay", "layer": "system", "hiddenByDefault": true },
    { "id": "settings-overlay", "layer": "system", "hiddenByDefault": true },
    { "id": "overlay", "layer": "system", "hiddenByDefault": true },
    { "id": "battle-result-overlay", "layer": "system", "hiddenByDefault": true },
    { "id": "battle-detail-overlay", "layer": "system", "hiddenByDefault": true },
    { "id": "board-preview-overlay", "layer": "system", "hiddenByDefault": true },
    { "id": "recipe-book-overlay", "layer": "system", "hiddenByDefault": true }
  ],
  "appSheets": [],
  "gamePanels": [
    { "id": "shop-panel", "phases": ["prep"], "modes": ["solo", "versus", "hardbot", "lobby", "campaign"] },
    { "id": "bench-panel", "phases": ["prep"], "modes": ["solo", "versus", "hardbot", "lobby", "campaign"] },
    { "id": "prep-top-bar", "phases": ["prep"], "modes": ["solo", "versus", "hardbot", "lobby", "campaign"] },
    { "id": "prep-field-column", "phases": ["prep", "battle", "replay"], "modes": ["*"] },
    { "id": "lobby-prep-field-roster", "phases": ["prep"], "modes": ["lobby"] },
    { "id": "lobby2p-prep-layout", "phases": ["prep"], "modes": ["lobby2p"] },
    { "id": "lobby2p-battle-hud", "phases": ["battle", "replay"], "modes": ["lobby2p"] },
    { "id": "campaign-hint-bar", "phases": ["prep"], "modes": ["campaign"] }
  ],
  "prepSnapshots": [
    {
      "name": "ipad-landscape-solo-prep",
      "mode": "solo",
      "target": "#prep-field-column"
    },
    {
      "name": "ipad-landscape-lobby-prep",
      "mode": "lobby",
      "target": "#prep-field-column"
    },
    {
      "name": "ipad-landscape-lobby2p-prep",
      "mode": "lobby2p",
      "target": "#lobby2p-prep-layout"
    }
  ],
  "layoutProfiles": [
    {
      "id": "iphone-portrait",
      "viewport": { "width": 430, "height": 932 },
      "expect": { "prepLayout": "mobile", "uiSurface": "phone-drawer", "battleProfile": "phone-portrait" }
    },
    {
      "id": "iphone-landscape",
      "viewport": { "width": 932, "height": 430 },
      "expect": { "prepLayout": "mobile", "uiSurface": "phone-landscape", "battleProfile": "phone-landscape" }
    },
    {
      "id": "ipad-landscape",
      "viewport": { "width": 1133, "height": 744 },
      "expect": { "prepLayout": "side", "uiSurface": "tablet-side", "battleProfile": "tablet-landscape-side" }
    },
    {
      "id": "desktop",
      "viewport": { "width": 1440, "height": 900 },
      "expect": { "prepLayout": "side", "uiSurface": "desktop", "battleProfile": "desktop-landscape" }
    }
  ]
}
