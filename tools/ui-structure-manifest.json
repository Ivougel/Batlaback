{
  "version": 1,
  "fixedAt": "2026-07-03",
  "gameModes": ["solo", "versus", "hardbot", "lobby", "td"],
  "phases": {
    "js": ["classSelect", "prep", "battle", "replay"],
    "appDataset": ["prep", "battle", "replay"]
  },
  "classIntroSteps": [
    { "key": "mode", "elementId": "class-step-mode", "overlayAttr": "mode" },
    { "key": "tdDifficulty", "elementId": "class-step-td-difficulty", "overlayAttr": "tdDifficulty" },
    { "key": "player", "elementId": "class-step-player", "overlayAttr": "player" },
    { "key": "companion", "elementId": "class-step-companion", "overlayAttr": "companion" },
    { "key": "summary", "elementId": "class-step-summary", "overlayAttr": "summary" },
    { "key": "opponent", "elementId": "class-step-opponent", "overlayAttr": "opponent" }
  ],
  "overlays": [
    { "id": "class-overlay", "layer": "menu", "hiddenByDefault": false },
    { "id": "escape-menu-overlay", "layer": "system", "hiddenByDefault": true },
    { "id": "settings-overlay", "layer": "system", "hiddenByDefault": true },
    { "id": "overlay", "layer": "system", "hiddenByDefault": true },
    { "id": "battle-result-overlay", "layer": "system", "hiddenByDefault": true },
    { "id": "battle-detail-overlay", "layer": "system", "hiddenByDefault": true },
    { "id": "board-preview-overlay", "layer": "system", "hiddenByDefault": true },
    { "id": "recipe-book-overlay", "layer": "system", "hiddenByDefault": true }
  ],
  "appSheets": [
    { "id": "td-loadout-sheet", "modes": ["td"] },
    { "id": "td-hero-sheet", "modes": ["td"] }
  ],
  "gamePanels": [
    { "id": "shop-panel", "phases": ["prep"], "modes": ["solo", "versus", "hardbot", "lobby", "td"] },
    { "id": "bench-panel", "phases": ["prep"], "modes": ["solo", "versus", "hardbot", "lobby", "td"] },
    { "id": "prep-top-bar", "phases": ["prep"], "modes": ["solo", "versus", "hardbot", "lobby", "td"] },
    { "id": "prep-field-column", "phases": ["prep", "battle", "replay"], "modes": ["*"] },
    { "id": "lobby-prep-roster-panel", "phases": ["prep"], "modes": ["lobby"] },
    { "id": "td-build-panel", "phases": ["prep", "battle"], "modes": ["td"], "requires": "tdRunLive" },
    { "id": "td-tower-panel", "phases": ["battle"], "modes": ["td"], "requires": "tdRunLive" },
    { "id": "td-hint-bar", "phases": ["prep", "battle"], "modes": ["td"], "requires": "tdRunLive" }
  ],
  "layoutProfiles": [
    {
      "id": "iphone-portrait",
      "viewport": { "width": 430, "height": 932 },
      "expect": { "prepLayout": "mobile", "uiSurface": "phone-drawer", "battleProfile": "phone-portrait" }
    },
    {
      "id": "iphone-landscape",
      "viewport": { "width": 932, "height": 430 },
      "expect": { "prepLayout": "side", "uiSurface": "tablet-side", "layoutProfile": "phone-landscape", "battleProfile": "phone-landscape" }
    },
    {
      "id": "ipad-portrait",
      "viewport": { "width": 768, "height": 1024 },
      "expect": { "prepLayout": "stacked", "uiSurface": "tablet-stacked", "battleProfile": "tablet-portrait", "tier": "tablet" }
    },
    {
      "id": "ipad-landscape",
      "viewport": { "width": 1024, "height": 768 },
      "expect": { "prepLayout": "side", "uiSurface": "tablet-side", "layoutProfile": "tablet-landscape", "battleProfile": "tablet-landscape-side", "tier": "tablet" }
    },
    {
      "id": "desktop",
      "viewport": { "width": 1440, "height": 1080 },
      "expect": { "prepLayout": "side", "uiSurface": "desktop", "layoutProfile": "desktop-landscape", "battleProfile": "desktop-landscape", "tier": "desktop" }
    }
  ],
  "prepSnapshots": [
    { "name": "ipad-landscape-solo-prep", "mode": "solo", "profile": "ipad-landscape", "target": "#app[data-phase=prep] .prep-left-column" },
    { "name": "ipad-landscape-lobby-prep", "mode": "lobby", "profile": "ipad-landscape", "target": "#app[data-phase=prep] .prep-left-column" }
  ]
}
